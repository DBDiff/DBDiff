{
  "main": "dbdiff.php",
  "output": "dist/dbdiff.phar",
  "compression": "GZ",
  "chmod": "0755",
  "check-requirements": true,
  "finder": [
    { "in": "src" },
    {
      "in": "vendor",
      "exclude": ["Tests", "tests", "test", "docs", "examples", "doc", "benchmark", "benchmarks"]
    }
  ],
  "stub": true,
  "shebang": "#!/usr/bin/env php",
  "banner": false,
  "metadata": {
    "version": "@git-version@"
  }
}
